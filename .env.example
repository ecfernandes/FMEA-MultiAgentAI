###############################################################################
# .env.example — copy to .env and fill in your real credentials
#
# NEVER commit the .env file to Git (it is already in .gitignore)
###############################################################################

# ----------------------------------------------------------------------------
# UTC LLM Platform (OpenAI-compatible)
# Key is sent via X-API-Key header from the frontend — this sets the fallback
# ----------------------------------------------------------------------------
UTCLLM_API_KEY=sk-your-llm-api-key-here

## Base URL for the LLM platform (any OpenAI-compatible endpoint)
LLM_BASE_URL=https://your-llm-platform/api/v1

## Default model (can be overridden by the user in the UI)
LLM_DEFAULT_MODEL=your-model-name

# ----------------------------------------------------------------------------
# PostgreSQL (db service)
# ----------------------------------------------------------------------------
POSTGRES_USER=appuser
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=app_db

# ----------------------------------------------------------------------------
# MinIO — Object storage for PDFs, audio, video files
# ----------------------------------------------------------------------------
MINIO_ROOT_USER=fmea_minio
MINIO_ROOT_PASSWORD=change_me_in_production
# Console UI: http://localhost:9001  |  API: http://localhost:9000

# ----------------------------------------------------------------------------
# Frontend (web service) — URL que o browser usa para chamar a API
# ----------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000
